---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import HomeSlider from '../components/HomeSlider.astro';
import Philosophy from '../components/Philosophy.astro';
import Services from '../components/Services.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Contact from '../components/Contact.astro';
const projects = await getCollection('work');
---
<MainLayout title="Maciej Wochna | Data Engineer">
    <main>
        <HomeSlider />
        
        <section id="about" class="bg-bg-primary section-standard">
            <div class="cnt-box">
                <Philosophy />
            </div>
        </section>

        <section id="services" class="bg-bg-secondary section-standard">
            <div class="cnt-box">
                <Services />
            </div>
        </section>

        <section id="portfolio" class="bg-bg-primary section-standard">
            <div class="cnt-box">
                <div class="grid-port">{projects.slice(0, 3).map(p => <ProjectCard project={p} />)}</div>
            </div>
        </section>

        <section id="contact" class="bg-bg-secondary section-standard relative">
            <div class="cnt-box flex flex-col justify-center h-full w-full relative">
                <div class="flex-grow flex items-center w-full">
                    <Contact />
                </div>
                
                <div class="w-full pt-12 border-t border-black/5 dark:border-white/5 mt-auto pb-6">
                    <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-center md:text-left">
                        <div class="text-sm text-text-secondary font-medium tracking-wide">
                            Copyright ©2026 All rights reserved | created by: <span class="text-text-primary font-bold">Maciej Wochna</span>
                        </div>
                        <div class="text-[10px] uppercase tracking-[2px] text-accent-primary/50 font-bold italic">
                            No large language models were harmed during the design and implementation of this website.
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</MainLayout>

<style is:global>
    section { width: 100%; min-height: 100dvh; height: auto; display: flex; align-items: center; justify-content: center; position: relative; }
    #home { height: 100dvh !important; }
    
    /* Unified Container - Content Centered */
    .cnt-box { 
        width: 100%; 
        max-width: 1400px; 
        margin: 0 auto; 
        padding: 6rem 1.5rem; 
        display: flex; 
        flex-direction: column; 
        align-items: center; 
        justify-content: center;
    }
    
    .grid-port { @apply grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-16 w-full; }

    @media (min-width: 1024px) {
        html { scroll-snap-type: y mandatory; }
        section { scroll-snap-align: start; scroll-snap-stop: always; height: 100vh; overflow: hidden; }
        #portfolio, #contact, #about, #services { height: auto; min-height: 100vh; }
        .cnt-box { padding: 0 1.5rem; height: 100%; }
    }
</style>