---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import HomeSlider from '../components/HomeSlider.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

// Pobranie projektów (zakładamy, że jest ich co najmniej 4-5 dla efektu Bento)
const projects = await getCollection('work');
// Sortowanie projektów (opcjonalne, np. po dacie lub priorytecie)
const sortedProjects = projects.sort((a, b) => a.data.priority - b.data.priority).slice(0, 5); 
---

<MainLayout title="Maciej Wochna | Data Engineer">
    <main class="snap-container">
        <HomeSlider />
        
        <section id="about" class="bg-bg-primary section-standard snap-section">
            <div class="cnt-box">
                <About />
            </div>
        </section>

        <section id="services" class="bg-bg-secondary section-standard snap-section">
            <div class="cnt-box">
                <Services />
            </div>
        </section>

        <section id="portfolio" class="bg-bg-primary section-standard snap-section">
            <div class="cnt-box">
                <div class="mb-12 text-center w-full">
                    <h2 class="text-3xl lg:text-5xl font-black uppercase tracking-tighter mb-4">Selected Work</h2>
                    <div class="w-24 h-1 bg-accent-primary mx-auto"></div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-4 w-full auto-rows-[300px]">
                    {sortedProjects.map((project, index) => {
                        // Logika Bento:
                        // Pierwszy element: Duży kwadrat (2x2)
                        // Czwarty element: Szeroki prostokąt (2x1)
                        // Pozostałe: Standardowe (1x1)
                        let bentoClass = "md:col-span-1 md:row-span-1";
                        
                        if (index === 0) {
                            bentoClass = "md:col-span-2 md:row-span-2";
                        } else if (index === 3) {
                            bentoClass = "md:col-span-2 md:row-span-1";
                        }

                        return (
                            <div class={`relative group overflow-hidden rounded-3xl ${bentoClass}`}>
                                <ProjectCard project={project} class="h-full w-full" />
                            </div>
                        );
                    })}
                </div>
                
                <div class="mt-12 w-full text-center">
                    <a href="/portfolio" class="inline-block border-b-2 border-current pb-1 font-bold tracking-widest hover:text-accent-primary hover:border-accent-primary transition-all">
                        VIEW ALL PROJECTS
                    </a>
                </div>
            </div>
        </section>

        <section id="contact" class="bg-bg-secondary relative snap-section flex flex-col">
            <div class="cnt-box flex items-center justify-center flex-grow py-20">
                <Contact />
            </div>
            <Footer />
        </section>
    </main>
</MainLayout>

<style is:global>
    /* Podstawowy styl sekcji */
    section { 
        width: 100%;
        min-height: 100dvh; 
        height: auto; 
        display: flex; 
        flex-direction: column;
        align-items: center; 
        justify-content: center; 
        position: relative;
        padding-top: 80px;
        padding-bottom: 0;
    }
    
    #home { 
        height: 100dvh!important; 
        padding: 0;
    }
    
    #contact {
        justify-content: space-between;
        padding-bottom: 0;
    }
    
    .cnt-box { 
        width: 100%;
        max-width: 1400px; 
        margin: 0 auto; 
        padding: 0 1.5rem; 
        display: flex; 
        flex-direction: column; 
        align-items: center; 
        justify-content: center;
    }

    /* SCROLL SNAP PROXIMITY (Desktop) */
    @media (min-width: 1024px) {
        html { 
            scroll-snap-type: y proximity; 
        }
        
        .snap-section { 
            scroll-snap-align: start; 
            scroll-snap-stop: normal;
        }
        
        section {
            height: auto;
            min-height: 100vh;
            padding-top: 100px;
        }
        
        #home {
            height: 100vh!important;
        }
    }
</style>