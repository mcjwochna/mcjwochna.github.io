---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Philosophy from '../components/Philosophy.astro';
import Contact from '../components/Contact.astro';

const projects = await getCollection('work');
---

<MainLayout>
    
    <section class="min-h-[60vh] flex flex-col justify-center border-b border-bg-secondary pb-12">
        <span class="text-accent-primary font-mono text-sm mb-4">01. INTRODUCTION</span>
        <h2 class="text-3xl md:text-5xl font-bold leading-tight mb-6">
            Specjalizuję się w <span class="text-white">Azure Fabric</span> oraz <span class="text-white">modelowaniu danych</span>. Buduję pipeline'y, które są skalowalne, oszczędne i logiczne.
        </h2>
        <p class="text-text-secondary max-w-2xl text-lg mb-8">
            Dla mnie Data Engineering to nie tylko przesuwanie bajtów. To architektura decyzji. Zobacz, jak zamieniam surowe dane w actionable insights.
        </p>
        <div>
            <a href="#work" class="inline-block border border-text-secondary px-8 py-3 text-sm hover:border-accent-primary hover:text-accent-primary transition-colors">
                ZOBACZ PROJEKTY ↓
            </a>
        </div>
    </section>

    <section id="work">
        <span class="text-accent-primary font-mono text-sm mb-8 block">02. SELECTED WORK</span>
        <div class="grid gap-12">
            {projects.map(project => (
                <ProjectCard project={project} />
            ))}
        </div>
    </section>

    <Philosophy />

    <Contact />

</MainLayout>