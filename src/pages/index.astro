---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import HomeSlider from '../components/HomeSlider.astro';
import Philosophy from '../components/Philosophy.astro';
import Services from '../components/Services.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Contact from '../components/Contact.astro';

const projects = await getCollection('work');
---

<MainLayout title="Maciej Wochna | Data Engineer">
    
    <main>
        <HomeSlider />

        <section id="about" class="bg-bg-primary transition-colors duration-300">
            <div class="max-w-[1400px] mx-auto px-6 py-24 lg:pt-32">
                <div class="mb-12 border-l-4 border-accent-primary pl-6">
                    <span class="text-accent-primary font-mono text-sm tracking-[4px] uppercase block mb-2">01. About</span>
                    <h2 class="text-3xl md:text-5xl font-black text-gray-900 dark:text-white uppercase tracking-tighter">
                        About Me
                    </h2>
                </div>
                <Philosophy />
            </div>
        </section>

        <Services />

        <section id="portfolio" class="bg-bg-primary transition-colors duration-300">
            <div class="max-w-[1500px] mx-auto px-6 py-24 lg:pt-32 flex flex-col h-full w-full">
                <div class="mb-12 border-l-4 border-accent-primary pl-6">
                    <span class="text-accent-primary font-mono text-sm tracking-[4px] uppercase block mb-2">02. Portfolio</span>
                    <h2 class="text-3xl md:text-5xl font-black text-gray-900 dark:text-white uppercase tracking-tighter">
                        Portfolio
                    </h2>
                </div>

                <div class="flex-grow flex items-center justify-center">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-16 w-full">
                        {projects.slice(0, 3).map(project => (
                            <div class="w-full">
                                <ProjectCard project={project} />
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <Contact />
    </main>

</MainLayout>

<style is:global>
    /* BAZA DLA SEKCI - RESPONSYWNA */
    section {
        min-height: 100vh; /* Na mobile sekcja rośnie z treścią */
        width: 100%;
        position: relative;
        display: flex;
        flex-direction: column;
    }

    /* DESKTOP: Wymuszamy dociąganie i stałą wysokość tylko jeśli ekran jest duży */
    @media (min-width: 1024px) {
        section {
            height: calc(100vh - 80px);
            overflow: hidden;
            scroll-snap-align: start;
            scroll-snap-stop: always;
        }

        /* Home zajmuje zawsze pełny ekran */
        #home {
            height: 100vh !important;
        }

        /* Sekcje z dużym kontentem mogą być wyższe jeśli trzeba */
        #portfolio, #about, #contact {
            height: auto;
            min-height: 100vh;
        }
    }
</style>