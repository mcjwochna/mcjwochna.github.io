---
---
<div class="w-full max-w-6xl mx-auto px-4 py-20">
    <div class="text-center mb-16">
        <h2 class="text-4xl lg:text-5xl font-black mb-4 tracking-tighter">Let's Talk Data</h2>
        <p class="text-text-secondary text-lg max-w-2xl mx-auto">Masz dane, które potrzebują struktury? Projekt, który wymaga analizy? Skontaktuj się ze mną.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
        
        <!-- LEWA STRONA: Formularz -->
<form class="glass-card p-8 lg:p-10 rounded-3xl space-y-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <input type="text" class="w-full bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-accent-primary focus:bg-white dark:focus:bg-black/40 transition-all placeholder:text-gray-400" placeholder="Your Name" />
        <input type="email" class="w-full bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-accent-primary focus:bg-white dark:focus:bg-black/40 transition-all placeholder:text-gray-400" placeholder="Your Email" />
    </div>
    <input type="text" class="w-full bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-accent-primary focus:bg-white dark:focus:bg-black/40 transition-all placeholder:text-gray-400" placeholder="Project Inquiry" />
    <textarea rows="5" class="w-full bg-white/50 dark:bg-black/20 border border-gray-200 dark:border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-accent-primary focus:bg-white dark:focus:bg-black/40 transition-all placeholder:text-gray-400" placeholder="Hi Maciej, I would like to discuss a potential Data Engineering project with you..."></textarea>
    <button type="submit" class="w-full bg-accent-primary text-white font-bold py-4 rounded-xl uppercase tracking-widest hover:bg-accent-primary/90 hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-accent-primary/20">
        Wyślij Wiadomość
    </button>
</form>

        <!-- PRAWA STRONA: Dane kontaktowe -->
        <div class="glass-card p-8 lg:p-10 rounded-3xl flex flex-col justify-center gap-8 text-left h-full">
            <div>
                <h3 class="text-2xl font-bold mb-2">Dane Kontaktowe</h3>
                <p class="text-text-secondary text-sm">Jestem dostępny do projektów freelance oraz stałej współpracy.</p>
            </div>
            
            <div class="space-y-6">
                <!-- Phone -->
                <div class="flex items-start gap-5 group">
                    <div class="w-12 h-12 rounded-2xl bg-accent-primary/10 flex items-center justify-center text-accent-primary group-hover:scale-110 transition-transform duration-300">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-xs uppercase font-bold text-text-secondary tracking-widest mb-1">Telefon</p>
                        <a href="tel:+48603234834" class="text-lg font-bold hover:text-accent-primary transition-colors">+48 603 234 834</a>
                    </div>
                </div>

                <!-- Email -->
                <div class="flex items-start gap-5 group">
                    <div class="w-12 h-12 rounded-2xl bg-accent-primary/10 flex items-center justify-center text-accent-primary group-hover:scale-110 transition-transform duration-300">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                    <div>
                        <p class="text-xs uppercase font-bold text-text-secondary tracking-widest mb-1">Email</p>
                        <a href="mailto:maciej.wochna@gmail.com" class="text-lg font-bold hover:text-accent-primary transition-colors">maciej.wochna@gmail.com</a>
                    </div>
                </div>
                
                <!-- LinkedIn -->
                <div class="flex items-start gap-5 group">
                    <div class="w-12 h-12 rounded-2xl bg-accent-primary/10 flex items-center justify-center text-accent-primary group-hover:scale-110 transition-transform duration-300">
                        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                    </div>
                    <div>
                        <p class="text-xs uppercase font-bold text-text-secondary tracking-widest mb-1">LinkedIn</p>
                        <a href="https://linkedin.com/in/maciejwochna" class="text-lg font-bold hover:text-accent-primary transition-colors">/in/maciejwochna</a>
                    </div>
                </div>

                <!-- Website -->
                <div class="flex items-start gap-5 group">
                    <div class="w-12 h-12 rounded-2xl bg-accent-primary/10 flex items-center justify-center text-accent-primary group-hover:scale-110 transition-transform duration-300">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
                        </svg>
                    </div>
                    <div>
                        <p class="text-xs uppercase font-bold text-text-secondary tracking-widest mb-1">Strona</p>
                        <a href="https://maciejwochna.pl" class="text-lg font-bold hover:text-accent-primary transition-colors">maciejwochna.pl</a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.6);
        box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.05);
    }
    
    :global(.dark) .glass-card {
        background: rgba(20, 20, 20, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.5);
    }
</style>

<style>
    /* Stylizacja Glassmorphism - Klucz do efektu Apple */
   .glass-card {
        /* Baza dla trybu jasnego: biały z dużą przezroczystością */
        background: rgba(255, 255, 255, 0.6);
        /* Efekt rozmycia tła pod spodem */
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        /* Subtelny border imitujący krawędź szkła */
        border: 1px solid rgba(255, 255, 255, 0.6);
        /* Cień dla głębi */
        box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.05);
    }
    
    /* Wariant dla trybu ciemnego */
    :global(.dark).glass-card {
        background: rgba(20, 20, 20, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.5);
    }
</style>