---
// Ikony SVG w stylu Apple SF Symbols: stroke-width 1.5, rounded caps, geometryczna precyzja
const services = [
  { 
    title: "UX Design", 
    desc: "Tworzenie intuicyjnych i estetycznych interfejsów dla raportów Power BI.",
    // Kwadrat z kursorem — reprezentacja interfejsu
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 12l3 3 6-6"/></svg>`
  },
  { 
    title: "Dashboard Design", 
    desc: "Projektowanie czytelnych dashboardów wspierających szybkie decyzje.",
    // Grid modułowy — esencja dashboardu
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/></svg>`
  },
  { 
    title: "SQL Development", 
    desc: "Budowa i optymalizacja zapytań w celu przyspieszenia odświeżania danych.",
    // Cylinder bazy danych — uniwersalny symbol
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/></svg>`
  },
  { 
    title: "ETL Processes", 
    desc: "Automatyzacja przepływu danych przy użyciu Azure Fabric i Spark.",
    // Przepływ: trzy węzły połączone — transformacja danych
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="12" r="2"/><circle cx="19" cy="6" r="2"/><circle cx="19" cy="18" r="2"/><path d="M7 11l8-4"/><path d="M7 13l8 4"/></svg>`
  },
  { 
    title: "Data Modeling", 
    desc: "Tworzenie skalowalnych schematów gwiazdy i relacyjnych baz danych.",
    // Schemat gwiazdy — dosłowna reprezentacja star schema
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><circle cx="12" cy="3" r="1.5"/><circle cx="21" cy="12" r="1.5"/><circle cx="12" cy="21" r="1.5"/><circle cx="3" cy="12" r="1.5"/><line x1="12" y1="9" x2="12" y2="4.5"/><line x1="15" y1="12" x2="19.5" y2="12"/><line x1="12" y1="15" x2="12" y2="19.5"/><line x1="9" y1="12" x2="4.5" y2="12"/></svg>`
  },
  { 
    title: "Business Analysis", 
    desc: "Przekładanie potrzeb biznesowych na konkretne rozwiązania techniczne.",
    // Trend wzrostowy — analiza i insight
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`
  }
];
---

<section id="services" class="bg-bg-secondary transition-colors duration-300">
  <div class="max-w-[1400px] mx-auto px-6">
    <div class="text-center mb-16">
      <span class="text-accent-primary font-mono text-sm tracking-[4px] uppercase block mb-4">02. Services</span>
      <h2 class="text-3xl md:text-5xl font-extrabold text-gray-900 dark:text-white uppercase">What I'm good at</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map(service => (
        <div class="group p-10 bg-bg-primary dark:bg-white/5 border border-black/5 dark:border-white/10 rounded-2xl transition-all duration-500 hover:shadow-2xl hover:-translate-y-2 text-center">
          
          <!-- Ikona SVG: 48x48, subtelna animacja koloru -->
          <div 
            class="w-12 h-12 mx-auto mb-6 text-gray-400 dark:text-gray-500 group-hover:text-accent-primary transition-colors duration-500"
            set:html={service.icon}
          />
          
          <h3 class="text-xl font-bold mb-4 text-gray-900 dark:text-white uppercase tracking-wider">
            {service.title}
          </h3>
          
          <p class="text-text-secondary text-sm leading-relaxed">
            {service.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>