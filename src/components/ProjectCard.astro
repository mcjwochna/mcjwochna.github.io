---
const { project } = Astro.props;
const { title, description, tags } = project.data;
const { slug } = project;
---

<a href={`/work/${slug}`} class="block group bg-bg-secondary p-8 hover:bg-bg-tertiary transition-all duration-300">
    <div class="flex flex-col gap-4">
        <div class="flex justify-between items-start">
            <h3 class="text-2xl font-bold text-white group-hover:text-accent-primary transition-colors">
                {title}
            </h3>
            <span class="text-accent-primary opacity-0 group-hover:opacity-100 transition-opacity">↗</span>
        </div>
        
        <p class="text-text-secondary text-sm leading-relaxed max-w-2xl">
            {description}
        </p>

        <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-white/5">
            {tags.map((tag) => (
                <span class="text-xs font-mono text-text-secondary">
                    #{tag}
                </span>
            ))}
        </div>
    </div>
</a>