---
const { project } = Astro.props;
const { title, description, tags } = project.data;
const { slug } = project;
---

<a href={`/work/${slug}`} class="group relative block p-8 rounded-2xl border border-white/10 bg-white/5 backdrop-blur-md transition-all duration-500 hover:border-accent-primary/50 hover:bg-white/10 hover:shadow-[0_0_30px_rgba(16,185,129,0.15)] hover:-translate-y-1">
    
    <div class="flex flex-col gap-4 relative z-10">
        <div class="flex justify-between items-start">
            <h3 class="text-2xl font-bold text-white group-hover:text-accent-primary transition-colors duration-300">
                {title}
            </h3>
            
            <span class="text-accent-primary opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 font-mono text-xl">
                ↗
            </span>
        </div>
        
        <p class="text-text-secondary text-sm leading-relaxed max-w-2xl group-hover:text-gray-300 transition-colors">
            {description}
        </p>

        <div class="flex flex-wrap gap-2 mt-4 pt-4 border-t border-white/5 group-hover:border-white/10 transition-colors">
            {tags.map((tag) => (
                <span class="text-xs font-mono text-accent-primary/70 bg-accent-primary/5 px-2 py-1 rounded border border-accent-primary/10 group-hover:border-accent-primary/30 transition-colors">
                    #{tag}
                </span>
            ))}
        </div>
    </div>
</a>