---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import { SITE } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${SITE.name} | Data Engineer & BI Developer`,
  description = 'Specializing in ETL/ELT pipelines, data modeling, and Power BI dashboards. Microsoft Fabric | Azure Synapse | SQL Server.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE.url);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.name,
  jobTitle: SITE.schema.jobTitle,
  url: SITE.url,
  sameAs: [SITE.social.linkedin.url, SITE.social.github.url],
  knowsAbout: SITE.schema.skills,
  email: SITE.contact.email,
  telephone: SITE.contact.phone,
  address: {
    '@type': 'PostalAddress',
    addressCountry: SITE.schema.addressCountry,
  },
};
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Performance: preconnect to external origins -->
    <link rel="preconnect" href="https://in2data.pl" />
    <link rel="dns-prefetch" href="https://app.powerbi.com" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={SITE.name} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Theme color for browser chrome -->
    <meta name="theme-color" content="#10b981" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />

    <!-- Open Graph / Facebook / LinkedIn -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(SITE.ogImage, SITE.url)} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={`${SITE.name} - Data Engineer Portfolio`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(SITE.ogImage, SITE.url)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Structured Data (Schema.org) -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />

    <!-- Dark mode: applied before render to prevent flash of wrong theme -->
    <script is:inline>
        const theme = localStorage.getItem('theme') ??
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', theme === 'dark');
        localStorage.setItem('theme', theme);
    </script>
</head>
<body class="bg-bg-primary text-text-primary antialiased overflow-x-hidden flex flex-col min-h-screen transition-colors duration-300 selection:bg-accent-primary selection:text-white">

    <Navbar />

    <main class="flex-grow">
        <slot />
    </main>
</body>
</html>
