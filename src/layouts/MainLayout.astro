---
// Importujemy globalne style (reset CSS, fonty, definicje kolorów)
import '../styles/global.css';

// Pobieramy tytuł strony z właściwości (props) lub ustawiamy domyślny
const { title = "Maciej Wochna | Data Engineer" } = Astro.props;
---

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Maciej Wochna | Senior Data Engineer" />
    <meta property="og:description" content="Specjalizuję się w Azure Fabric i Power BI. Zobacz moje interaktywne portfolio." />
    <meta property="og:image" content="https://mcjwochna.github.io/og-image.jpg" />
    <meta property="og:url" content="https://mcjwochna.github.io/" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-bg-primary text-text-primary antialiased selection:bg-accent-primary selection:text-bg-primary">
    
    <div class="max-w-[1400px] mx-auto px-6 py-0 lg:py-12 lg:grid lg:grid-cols-12 lg:gap-16 min-h-screen">
        
        <header class="lg:col-span-3 sticky top-0 z-50 bg-bg-primary/95 backdrop-blur-md lg:bg-transparent lg:backdrop-blur-none -mx-6 px-6 py-4 lg:mx-0 lg:p-0 lg:sticky lg:top-12 lg:h-[calc(100vh-6rem)] flex flex-row lg:flex-col justify-between items-center lg:items-start border-b border-white/10 lg:border-none mb-8 lg:mb-0 transition-all duration-300">
            
            <div class="flex flex-col">
                <h1 class="text-xl lg:text-4xl font-bold tracking-tight lg:mb-2 leading-tight">
                    <a href="/" class="hover:text-accent-primary transition-colors block">
                        Maciej<br class="hidden lg:block"> <span class="lg:text-white">Wochna.</span>
                    </a>
                </h1>
                <p class="text-text-secondary text-xs lg:text-sm font-medium hidden lg:block lg:mb-8">
                    Senior Data Engineer
                </p>
                
                <div class="mb-12 hidden lg:block">
                    <img 
                        src="/profile.jpg" 
                        alt="Maciej Wochna" 
                        class="w-48 h-48 object-cover rounded-xl shadow-2xl grayscale hover:grayscale-0 transition-all duration-700 border border-white/10"
                    >
                </div>
        
                <nav class="flex flex-row lg:flex-col gap-4 lg:mt-12 ml-4 lg:ml-0 items-center lg:items-start">
                    <a href="#work" data-target="work" class="nav-link text-text-secondary hover:text-white transition-all duration-300 text-[10px] sm:text-xs lg:text-sm uppercase tracking-widest border-b-2 lg:border-b-0 lg:border-l-2 border-transparent lg:pl-4 flex items-center group py-2 lg:py-0">
                        <span class="hidden lg:inline group-hover:text-accent-primary transition-colors mr-4">01.</span> 
                        <span>Projekty</span>
                    </a>
                    
                    <a href="#philosophy" data-target="philosophy" class="nav-link text-text-secondary hover:text-white transition-all duration-300 text-[10px] sm:text-xs lg:text-sm uppercase tracking-widest border-b-2 lg:border-b-0 lg:border-l-2 border-transparent lg:pl-4 flex items-center group py-2 lg:py-0">
                        <span class="hidden lg:inline group-hover:text-accent-primary transition-colors mr-4">02.</span> 
                        <span>Filozofia</span>
                    </a>
                    
                    <a href="#contact" data-target="contact" class="nav-link text-text-secondary hover:text-white transition-all duration-300 text-[10px] sm:text-xs lg:text-sm uppercase tracking-widest border-b-2 lg:border-b-0 lg:border-l-2 border-transparent lg:pl-4 flex items-center group py-2 lg:py-0">
                        <span class="hidden lg:inline group-hover:text-accent-primary transition-colors mr-4">03.</span> 
                        <span>Kontakt</span>
                    </a>
                </nav>
            </div>

            <div class="text-text-secondary text-sm hidden lg:block opacity-50">
                © {new Date().getFullYear()}
            </div>
        </header>

        <main class="lg:col-span-9 flex flex-col gap-0 mt-4 lg:mt-0">
            <slot />
        </main>

    </div>

    <style>
        /* Styl aktywnego linku (podświetlenie) */
        .nav-link.active {
            color: #fff;
            /* Desktop: Pasek z lewej */
            @media (min-width: 1024px) {
                border-left-color: #10b981;
                padding-left: 1.5rem;
                background: linear-gradient(90deg, rgba(16,185,129,0.05) 0%, transparent 100%);
            }
            /* Mobile: Pasek z dołu */
            @media (max-width: 1023px) {
                border-bottom-color: #10b981;
            }
        }

        /* Animacja wejścia (Fade In Up) */
        .fade-in-section {
            opacity: 0;
            transform: translateY(30px);
            transition: opacity 0.8s ease-out, transform 0.8s ease-out;
            will-change: opacity, transform;
        }
        
        .fade-in-section.is-visible {
            opacity: 1;
            transform: translateY(0);
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            
            // --- 1. ACTIVE NAV (OBSERWATOR SEKCJI) ---
            const navOptions = {
                root: null,
                // Przesunięcie strefy wykrywania:
                // Mobile: Wykrywaj sekcje na środku ekranu
                rootMargin: '-20% 0px -60% 0px', 
                threshold: 0
            };

            const navObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        // Reset wszystkich linków
                        document.querySelectorAll('.nav-link').forEach(link => link.classList.remove('active'));
                        
                        // Aktywacja obecnego
                        const id = entry.target.getAttribute('id');
                        const activeLink = document.querySelector(`.nav-link[data-target="${id}"]`);
                        if (activeLink) activeLink.classList.add('active');
                    }
                });
            }, navOptions);

            // Obserwuj główne sekcje
            document.querySelectorAll('section[id]').forEach(section => navObserver.observe(section));


            // --- 2. FADE IN ANIMATIONS (WEJŚCIA KINOWE) ---
            const fadeObserver = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('is-visible');
                        observer.unobserve(entry.target); // Animuj tylko raz
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('section > *').forEach(el => {
                el.classList.add('fade-in-section');
                fadeObserver.observe(el);
            });
        });
    </script>
</body>
</html>